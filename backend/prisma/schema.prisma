generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

model Organization {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  email        String       @unique
  /** Custom leave policy document (JSON); null = use built-in default. */
  leavePolicy  Json?
  createdAt    DateTime     @default(now())
  users        User[]
  teams        Team[]
  departments  Department[]
  holidays     Holiday[]
  leaves       Leave[]
  compOffWorkLogs CompOffWorkLog[]
  permissionRequests PermissionRequest[]
}

model Department {
  id             Int      @id @default(autoincrement())
  name           String
  organizationId Int
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teams        Team[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Team {
  id             Int    @id @default(autoincrement())
  name           String
  organizationId Int
  departmentId   Int
  managerId      Int?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  department   Department   @relation(fields: [departmentId], references: [id])

  members User[]
  leaves  Leave[]

  @@unique([name, departmentId])
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  role     Role    @default(EMPLOYEE)
  isActive Boolean @default(true)
  gender   Gender?
  /** Calendar date (time ignored) for upcoming birthdays on admin dashboard */
  birthDate DateTime?
  /** Calendar date (time ignored) for employment start / joining */
  joiningDate DateTime?

  organizationId Int
  teamId         Int?

  /** Optional line manager (must be MANAGER or ADMIN in the same org). */
  reportingManagerId Int?
  reportingManager   User?  @relation("UserReportingManager", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  directReports      User[] @relation("UserReportingManager")

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  team         Team?        @relation(fields: [teamId], references: [id])

  leaves       Leave[]
  leaveBalance LeaveBalance?
  compOffWorkLogs CompOffWorkLog[]
  permissionRequests PermissionRequest[]

  @@index([reportingManagerId])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  ANNUAL
  SICK
  COMP_OFF
  MATERNITY
  PATERNITY
}

model Leave {
  id             Int         @id @default(autoincrement())
  userId         Int
  organizationId Int
  teamId         Int?
  type           LeaveType
  startDate      DateTime
  endDate        DateTime
  reason         String
  rejectionReason String?
  status         LeaveStatus @default(PENDING)

  approvedById Int?

  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  team         Team?        @relation(fields: [teamId], references: [id])

  @@index([userId, status])
  @@index([organizationId])
  @@index([teamId])
  @@index([status])
}

model LeaveBalance {
  id        Int  @id @default(autoincrement())
  userId    Int  @unique
  sick      Int  @default(12)
  annual    Int  @default(12)
  compOff   Int  @default(0)
  maternity Int  @default(180)
  paternity Int  @default(15)
  user      User @relation(fields: [userId], references: [id])
}

model CompOffWorkLog {
  id             Int      @id @default(autoincrement())
  userId         Int
  organizationId Int
  workDate       DateTime
  reason         String
  status         RequestStatus @default(PENDING)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, workDate])
  @@index([organizationId, workDate])
}

model Holiday {
  id   Int      @id @default(autoincrement())
  date DateTime
  name String

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([date, organizationId])
}

model PermissionRequest {
  id              Int            @id @default(autoincrement())
  userId          Int
  organizationId  Int
  date            DateTime
  durationMinutes Int
  /** Minutes from midnight (0–1439) for in-between-time permission */
  startTimeMinutes Int?
  endTimeMinutes   Int?
  reason          String
  status          RequestStatus @default(PENDING)
  createdAt       DateTime       @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([organizationId, date])
}
