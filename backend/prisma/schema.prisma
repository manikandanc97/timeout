generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

model Organization {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  email        String       @unique
  phoneNumber  String?
  officeAddress String?
  timezone     String       @default("Asia/Kolkata")
  currency     String       @default("INR")
  dateFormat   String       @default("DD/MM/YYYY")
  adminSettings Json?
  /** Custom leave policy document (JSON); null = use built-in default. */
  leavePolicy  Json?
  createdAt    DateTime     @default(now())
  users        User[]
  teams        Team[]
  departments  Department[]
  holidays     Holiday[]
  leaves       Leave[]
  salaryStructures SalaryStructure[]
  payrolls     Payroll[]
  compOffWorkLogs CompOffWorkLog[]
  permissionRequests PermissionRequest[]
  notifications Notification[]
  hrPolicies    HrPolicy[]
}

model Department {
  id             Int      @id @default(autoincrement())
  name           String
  organizationId Int
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teams        Team[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Team {
  id             Int    @id @default(autoincrement())
  name           String
  organizationId Int
  departmentId   Int
  managerId      Int?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  department   Department   @relation(fields: [departmentId], references: [id])

  members User[]
  leaves  Leave[]

  @@unique([name, departmentId])
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  role     Role    @default(EMPLOYEE)
  designation String?
  isActive Boolean @default(true)
  gender   Gender?
  /** Calendar date (time ignored) for upcoming birthdays on admin dashboard */
  birthDate DateTime?
  /** Calendar date (time ignored) for employment start / joining */
  joiningDate DateTime?

  organizationId Int
  teamId         Int?

  /** Optional line manager (must be MANAGER or ADMIN in the same org). */
  reportingManagerId Int?
  reportingManager   User?  @relation("UserReportingManager", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  directReports      User[] @relation("UserReportingManager")

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  team         Team?        @relation(fields: [teamId], references: [id])

  leaves       Leave[]
  salaryStructures SalaryStructure[]
  payrolls     Payroll[]
  leaveBalance LeaveBalance?
  compOffWorkLogs CompOffWorkLog[]
  permissionRequests PermissionRequest[]
  notifications Notification[]

  @@index([reportingManagerId])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  PENDING
  PAID
}

enum LeaveType {
  ANNUAL
  SICK
  COMP_OFF
  MATERNITY
  PATERNITY
}

enum NotificationType {
  LEAVE_APPLIED
  LEAVE_APPROVED
  LEAVE_REJECTED
  LEAVE_CANCELLED
  PERMISSION_APPLIED
  PERMISSION_APPROVED
  PERMISSION_REJECTED
  COMP_OFF_APPLIED
  COMP_OFF_APPROVED
  COMP_OFF_REJECTED
  EMPLOYEE_ADDED
  EMPLOYEE_UPDATED
  EMPLOYEE_DEACTIVATED
  EMPLOYEE_REACTIVATED
  SALARY_STRUCTURE_UPDATED
  HOLIDAY_CREATED
  HOLIDAY_UPDATED
  HOLIDAY_DELETED
  LEAVE_POLICY_UPDATED
  ADMIN_SETTINGS_UPDATED
  ORG_STRUCTURE_UPDATED
  PAYROLL_UPDATED
  PAYSLIP_PAID
}

model Notification {
  id             Int              @id @default(autoincrement())
  userId         Int
  organizationId Int
  type           NotificationType
  title          String
  body           String?
  readAt         DateTime?
  leaveId        Int?
  createdAt      DateTime         @default(now())

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leave          Leave?           @relation(fields: [leaveId], references: [id], onDelete: SetNull)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model Leave {
  id             Int         @id @default(autoincrement())
  userId         Int
  organizationId Int
  teamId         Int?
  type           LeaveType
  startDate      DateTime
  endDate        DateTime
  reason         String
  rejectionReason String?
  status         LeaveStatus @default(PENDING)
  /** Days deducted from leave balance at request time */
  balanceDeductedDays Int @default(0)
  /** Days allowed as Loss of Pay when balance is insufficient */
  lopDays        Int @default(0)
  /** Estimated salary loss for LOP days */
  lopAmount      Float @default(0)

  approvedById Int?

  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  team         Team?        @relation(fields: [teamId], references: [id])
  notifications Notification[]

  @@index([userId, status])
  @@index([organizationId])
  @@index([teamId])
  @@index([status])
}

model LeaveBalance {
  id        Int  @id @default(autoincrement())
  userId    Int  @unique
  sick      Int  @default(12)
  annual    Int  @default(12)
  compOff   Int  @default(0)
  maternity Int  @default(180)
  paternity Int  @default(15)
  user      User @relation(fields: [userId], references: [id])
}

model CompOffWorkLog {
  id             Int      @id @default(autoincrement())
  userId         Int
  organizationId Int
  workDate       DateTime
  reason         String
  status         RequestStatus @default(PENDING)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, workDate])
  @@index([organizationId, workDate])
}

model Holiday {
  id   Int      @id @default(autoincrement())
  date DateTime
  name String

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([date, organizationId])
}

model PermissionRequest {
  id              Int            @id @default(autoincrement())
  userId          Int
  organizationId  Int
  date            DateTime
  durationMinutes Int
  /** Minutes from midnight (0–1439) for in-between-time permission */
  startTimeMinutes Int?
  endTimeMinutes   Int?
  reason          String
  status          RequestStatus @default(PENDING)
  createdAt       DateTime       @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([organizationId, date])
}

model SalaryStructure {
  id              Int      @id @default(autoincrement())
  userId          Int
  organizationId  Int
  yearlyGrossSalary Float?
  basicSalary     Float
  hra             Float    @default(0)
  allowance       Float    @default(0)
  bonus           Float    @default(0)
  pf              Float    @default(0)
  tax             Float    @default(0)
  professionalTax Float    @default(0)
  /** Running LOP days tracked against this active structure */
  lopDays         Int      @default(0)
  /** Running LOP amount tracked against this active structure */
  lopAmount       Float    @default(0)
  effectiveFrom   DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, effectiveFrom])
  @@index([userId, effectiveFrom])
}

model Payroll {
  id             Int           @id @default(autoincrement())
  userId         Int
  organizationId Int
  month          Int
  year           Int
  yearlyGrossSalary Float
  basicSalary    Float
  hra            Float         @default(0)
  allowance      Float         @default(0)
  bonus          Float         @default(0)
  pf             Float         @default(0)
  tax            Float         @default(0)
  professionalTax Float        @default(0)
  lopDays         Int          @default(0)
  lopAmount       Float        @default(0)
  netSalary      Float
  status         PayrollStatus @default(PENDING)
  paidDate       DateTime?
  createdAt      DateTime      @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, month, year])
  @@index([userId, month, year])
  @@unique([userId, month, year])
}

model HrPolicy {
  id             Int      @id @default(autoincrement())
  organizationId Int
  title          String
  category       String?
  content        String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

