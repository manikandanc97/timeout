# PRODUCTION ENVIRONMENT TEMPLATE
# Use this for staging and production deployments.
# Ensure all secrets are 32+ character random strings.

NODE_ENV="production"
PORT="5000"

# DATABASE
# Ensure you have pgvector installed for AI RAG features.
DATABASE_URL="postgresql://db_user:db_password@prod_host:5432/db_name?sslmode=require"

# SECURITY
# Generate with: openssl rand -base64 32
ACCESS_SECRET="REPLACE_WITH_SECURE_RANDOM_STRING"
REFRESH_SECRET="REPLACE_WITH_SECURE_RANDOM_STRING"

# CORS
CLIENT_ORIGIN="https://your-hrm-frontend.com"

# FRONTEND URL (for email links)
FRONTEND_URL="https://your-hrm-frontend.com"

# --- AI CONFIGURATION (DEMO) ---
# AI providers are managed via the Admin Settings UI.
# However, you can seed initial providers in the database.

# --- SMTP CONFIGURATION (PRODUCTION) ---
# These are the default values if not configured in the UI.
SMTP_HOST="smtp.provider.com"
SMTP_PORT="465"
SMTP_USER="notifications@yourdomain.com"
SMTP_PASS="secure_smtp_password"
SMTP_FROM="Timeout HRM <notifications@yourdomain.com>"
SMTP_SECURE="true"
