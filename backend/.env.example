# Copy this file to .env in the same folder (backend/.env) and fill in values.

NODE_ENV="development"
PORT="5000"

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE?schema=public"

# Use long random strings in production (e.g. openssl rand -base64 32)
ACCESS_SECRET="change-me-access-secret-min-32-chars"
REFRESH_SECRET="change-me-refresh-secret-min-32-chars"

# Allowed browser origin for Socket.IO CORS (match your Next.js dev URL)
CLIENT_ORIGIN="http://localhost:3000"

