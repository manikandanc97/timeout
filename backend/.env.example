# Timeout HRM - Backend Environment Variables
# Copy this file to .env and fill in the values below.

# --- Core Configuration ---
NODE_ENV="production"
PORT="5000"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# --- Security (REQUIRED in Production) ---
# Use long random strings (e.g. openssl rand -base64 32)
ACCESS_SECRET="your-32-char-access-secret"
REFRESH_SECRET="your-32-char-refresh-secret"

# Allowed browser origins for CORS (comma-separated)
# Keep localhost for dev and add your deployed frontend URL.
CLIENT_ORIGINS="http://localhost:3000,https://timeout-frontend.vercel.app"

# --- AI Assistant Configuration ---
# Active provider can be: gemini, openai, anthropic, groq, ollama, or demo
AI_PROVIDER="demo"
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"

# --- Email & SMTP (Notifications) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@timeout-hrm.com"

# --- Feature Flags ---
ENABLE_REGISTRATION="true"
ENABLE_AUDIT_LOGS="true"
