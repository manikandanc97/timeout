{
  "name": "timeout-hrm",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <25"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build --workspaces --if-present",
    "seed": "npm run db:seed -w backend",
    "setup": "npm install && npm run db:migrate -w backend && npm run seed",
    "test": "npm test -w backend",
    "test:coverage": "npm run test:coverage -w backend",
    "lint": "npm run lint -w frontend",
    "themeforest:package": "powershell -ExecutionPolicy Bypass -File scripts/export-themeforest.ps1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
