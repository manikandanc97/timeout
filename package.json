{
  "name": "timeout-hrm",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build --workspaces --if-present",
    "seed": "npm run db:seed -w backend",
    "setup": "npm install && npm run db:migrate -w backend && npm run seed",
    "test": "npm test -w backend",
    "test:coverage": "npm run test:coverage -w backend"
  },
  "dependencies": {
    "next": "^16.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
